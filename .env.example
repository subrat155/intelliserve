# GEMINI_API_KEY: 
# AI Studio automatically injects this at runtime from user secrets.
# For Vercel, set this in the Vercel dashboard.
GEMINI_API_KEY="your_gemini_api_key_here"

# For local development using Vite, use this prefix instead:
VITE_GEMINI_API_KEY="your_api_key_here"

# Clerk Authentication Publishable Key
# Get this from https://dashboard.clerk.com/~/api-keys
VITE_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key_here"

# APP_URL: The URL where this app is hosted.
# For Vercel, this is usually your deployment URL.
APP_URL="https://intelliserve3.vercel.app"
